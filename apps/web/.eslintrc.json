{
  "extends": [
    "next/core-web-vitals"
  ],
  "rules": {
    "react/no-unescaped-entities": "off"
  },
  "overrides": [
    {
      "files": [
        "src/app/**/*.{ts,tsx}",
        "src/components/**/*.{ts,tsx}",
        "src/services/**/*.{ts,tsx}",
        "src/lib/**/*.{ts,tsx}",
        "src/utils/**/*.{ts,tsx}",
        "src/hooks/**/*.{ts,tsx}"
      ],
      "excludedFiles": [
        "src/app/api/**/*",
        "src/**/*.test.{ts,tsx}",
        "src/**/__tests__/**/*",
        "src/lib/transformers.ts",
        "src/lib/notificationMapper.ts",
        "src/utils/notificationMapping.ts",
        "src/utils/notificationUserResolver.ts",
        "src/utils/userDataMapping.ts",
        "src/utils/auth.ts"
      ],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "selector": "MemberExpression[object.name=/^(post|notification|reaction|comment)$/][property.name=/.*_.*/]",
            "message": "Use camelCase in frontend-facing code. Normalize snake_case at API boundaries."
          },
          {
            "selector": "CallExpression[callee.object.name='localStorage'][callee.property.name='getItem'] > Literal[value='access_token']",
            "message": "Direct localStorage auth token access is forbidden. Use getAccessToken() from @/utils/auth instead."
          },
          {
            "selector": "CallExpression[callee.object.name='localStorage'][callee.property.name='setItem'] > Literal[value='access_token']",
            "message": "Direct localStorage auth token write is forbidden. Use setAccessToken() from @/utils/auth instead."
          },
          {
            "selector": "CallExpression[callee.object.name='localStorage'][callee.property.name='removeItem'] > Literal[value='access_token']",
            "message": "Direct localStorage auth token removal is forbidden. Use logout() from @/utils/auth instead."
          }
        ],
        "@next/next/no-img-element": "off"
      }
    },
    {
      "files": [
        "src/tests/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-syntax": [
          "warn",
          {
            "selector": "CallExpression[callee.object.name='localStorage'][callee.property.name='getItem'] > Literal[value='access_token']",
            "message": "Prefer (window.localStorage.getItem as jest.Mock).mockImplementation() in tests — see setup.ts."
          }
        ]
      }
    }
  ]
}
// Note: @next/next/no-img-element is disabled intentionally. 
// Grateful manages image optimization manually for uploaded content and modal previews, 
// making next/image unsuitable for several components.